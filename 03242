Public Sub OpenPDFWindow(ByVal strPath As String)
    ' 共用函數：檢查檔案並彈出 PDF 預覽視窗
    On Error GoTo ErrorHandler
    
    ' 1. 基本防呆：檢查路徑是否為空
    If Trim(strPath) = "" Then
        MsgBox "請提供 PDF 檔案路徑！", vbExclamation, "提示"
        Exit Sub
    End If
    
    ' 2. 檢查實體檔案到底存不存在
    If Dir(strPath) = "" Then
        MsgBox "找不到指定的 PDF 檔案！" & vbCrLf & "路徑: " & strPath, vbExclamation, "檔案遺失"
        Exit Sub
    End If
    
    ' 3. 呼叫專屬表單，並透過 OpenArgs 把路徑傳過去！
    ' acWindowNormal 代表正常開啟，您也可以改成 acDialog 強迫使用者看完必須關閉
    DoCmd.OpenForm "frmPDFViewer", WindowMode:=acWindowNormal, OpenArgs:=strPath
    
    Exit Sub
    
ErrorHandler:
    MsgBox "開啟 PDF 視窗時發生錯誤！" & vbCrLf & Err.Description, vbCritical, "系統錯誤"
End Sub
