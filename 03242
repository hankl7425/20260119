Public Sub ReconnectWithoutLoop()
    On Error GoTo ErrorHandler
    
    Dim strConn As String
    
    ' 這裡放入您解密後的完整連線字串 (必須包含 ODBC; 開頭)
    ' 範例: strConn = "ODBC;DRIVER={SQL Server};SERVER=您的伺服器IP;DATABASE=您的資料庫;UID=您的帳號;PWD=您的密碼;"
    strConn = "ODBC;DSN=您的DSN名稱;UID=您的帳號;PWD=您的密碼;" 
    
    ' 如果之前已經打開過，先關閉
    If Not g_dbCache Is Nothing Then
        g_dbCache.Close
        Set g_dbCache = Nothing
    End If
    
    ' ★ 效能魔法就在這一行：只開一個隱藏的連線，Access 就會記住密碼！
    ' 參數說明：("", False, False, 連線字串)
    Set g_dbCache = DBEngine.Workspaces(0).OpenDatabase("", False, False, strConn)
    
    MsgBox "資料庫連線已瞬間更新完成！", vbInformation, "系統提示"
    Exit Sub
    
ErrorHandler:
    MsgBox "更新連線失敗！" & vbCrLf & Err.Description, vbCritical, "錯誤"
End Sub
