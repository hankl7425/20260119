Private Sub btnOpenPDF_Click()
    ' 宣告變數來存放 PDF 的檔案路徑
    Dim strPDFPath As String
    
    ' 將這裡替換成您實際的 PDF 檔案路徑 (也可以替換成讀取某個欄位的值)
    strPDFPath = "C:\TestFolder\MyReport.pdf" 
    
    On Error GoTo ErrorHandler
    
    ' 1. 先檢查檔案到底存不存在，避免程式報錯
    If Dir(strPDFPath) <> "" Then
        ' 2. 檔案存在，直接呼叫預設程式開啟
        Application.FollowHyperlink strPDFPath
    Else
        MsgBox "找不到指定的 PDF 檔案！" & vbCrLf & "路徑: " & strPDFPath, vbExclamation, "檔案遺失"
    End If
    
    Exit Sub

ErrorHandler:
    MsgBox "開啟 PDF 時發生錯誤！" & vbCrLf & Err.Description, vbCritical, "錯誤"
End Sub
