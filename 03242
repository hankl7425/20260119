Public Function GetDSNUserIDPwd(strUserID As String) As String
    ' 模擬 VB.NET 讀取登錄檔並使用 3DES + SHA1 解密的邏輯
    On Error GoTo ErrorHandler
    
    Dim wsh As Object, fso As Object, ts As Object
    Dim psScriptPath As String, outFilePath As String
    Dim psCode As String, result As String

    If strUserID = "" Then Exit Function

    Set wsh = CreateObject("WScript.Shell")
    Set fso = CreateObject("Scripting.FileSystemObject")

    ' 1. 在暫存資料夾建立隨機檔名的腳本與輸出檔，避免衝突
    psScriptPath = wsh.ExpandEnvironmentStrings("%TEMP%") & "\dsn_" & fso.GetTempName() & ".ps1"
    outFilePath = wsh.ExpandEnvironmentStrings("%TEMP%") & "\out_" & fso.GetTempName() & ".txt"

    ' 2. 組成等價於原 VB.NET 邏輯的 PowerShell 程式碼
    ' (交由 PowerShell 讀取登錄檔可完美避開 32位元 Access 的 WOW6432Node 轉向問題)
    psCode = "$userId = '" & Replace(strUserID, "'", "''") & "'" & vbCrLf
    psCode = psCode & "$outPath = '" & Replace(outFilePath, "'", "''") & "'" & vbCrLf
    psCode = psCode & "try {" & vbCrLf
    psCode = psCode & "  $regPath = 'HKLM:\SOFTWARE\TEST'" & vbCrLf
    psCode = psCode & "  $pk = (Get-ItemProperty -Path $regPath -Name ""PK_$userId"" -ErrorAction Stop).""PK_$userId""" & vbCrLf
    psCode = psCode & "  $dsn = (Get-ItemProperty -Path $regPath -Name ""DSN_$userId"" -ErrorAction Stop).""DSN_$userId""" & vbCrLf
    psCode = psCode & "  if ([string]::IsNullOrWhiteSpace($pk) -or [string]::IsNullOrWhiteSpace($dsn)) { exit }" & vbCrLf
    psCode = psCode & "  $pk = $pk.Trim()" & vbCrLf
    
    ' 重現 Simple3Des 初始化與 TruncateHash 的邏輯
    psCode = psCode & "  $sha1 = [System.Security.Cryptography.SHA1]::Create()" & vbCrLf
    psCode = psCode & "  $3des = [System.Security.Cryptography.TripleDES]::Create()" & vbCrLf
    psCode = psCode & "  $kBytes = [System.Text.Encoding]::Unicode.GetBytes($pk)" & vbCrLf
    psCode = psCode & "  $hashK = $sha1.ComputeHash($kBytes)" & vbCrLf
    psCode = psCode & "  $finalK = New-Object byte[] 24" & vbCrLf ' 關鍵：強制轉換成 24 Bytes (補齊 4 個 0)
    psCode = psCode & "  [Array]::Copy($hashK, $finalK, [Math]::Min($hashK.Length, 24))" & vbCrLf
    psCode = psCode & "  $3des.Key = $finalK" & vbCrLf
    psCode = psCode & "  $iBytes = [System.Text.Encoding]::Unicode.GetBytes('')" & vbCrLf
    psCode = psCode & "  $hashI = $sha1.ComputeHash($iBytes)" & vbCrLf
    psCode = psCode & "  $finalI = New-Object byte[] 8" & vbCrLf
    psCode = psCode & "  [Array]::Copy($hashI, $finalI, [Math]::Min($hashI.Length, 8))" & vbCrLf
    psCode = psCode & "  $3des.IV = $finalI" & vbCrLf
    
    ' 重現 DecryptData 的邏輯
    psCode = psCode & "  $decBytes = [Convert]::FromBase64String($dsn)" & vbCrLf
    psCode = psCode & "  $ms = New-Object System.IO.MemoryStream" & vbCrLf
    psCode = psCode & "  $cs = New-Object System.Security.Cryptography.CryptoStream($ms, $3des.CreateDecryptor(), [System.Security.Cryptography.CryptoStreamMode]::Write)" & vbCrLf
    psCode = psCode & "  $cs.Write($decBytes, 0, $decBytes.Length)" & vbCrLf
    psCode = psCode & "  $cs.FlushFinalBlock()" & vbCrLf
    psCode = psCode & "  $res = [System.Text.Encoding]::Unicode.GetString($ms.ToArray())" & vbCrLf
    
    ' 以 Unicode (UTF-16) 輸出文字檔，確保中文或特殊字元不會變亂碼
    psCode = psCode & "  [IO.File]::WriteAllText($outPath, $res, [System.Text.Encoding]::Unicode)" & vbCrLf
    psCode = psCode & "} catch { }"

    ' 3. 將程式碼寫入暫存檔
    Set ts = fso.CreateTextFile(psScriptPath, True)
    ts.Write psCode
    ts.Close

    ' 4. 以「完全隱藏視窗 (-WindowStyle Hidden)」的方式執行 PowerShell
    ' 參數 0 代表隱藏，True 代表等待 PowerShell 執行完畢才繼續往下走
    wsh.Run "powershell.exe -ExecutionPolicy Bypass -NoProfile -WindowStyle Hidden -File """ & psScriptPath & """", 0, True

    ' 5. 讀取解密結果 (-1 代表以 Unicode 格式讀取)
    If fso.FileExists(outFilePath) Then
        Set ts = fso.OpenTextFile(outFilePath, 1, False, -1)
        If Not ts.AtEndOfStream Then
            result = ts.ReadAll()
        End If
        ts.Close
        GetDSNUserIDPwd = result
    End If

Cleanup:
    ' 6. 打掃戰場，刪除暫存檔釋放資源
    On Error Resume Next
    If fso.FileExists(psScriptPath) Then fso.DeleteFile psScriptPath
    If fso.FileExists(outFilePath) Then fso.DeleteFile outFilePath
    Set ts = Nothing
    Set fso = Nothing
    Set wsh = Nothing
    Exit Function

ErrorHandler:
    ' 遇到錯誤時默默結束，與原本 VB.NET 空白 Catch 區塊的行為保持一致
    Resume Cleanup
End Function

