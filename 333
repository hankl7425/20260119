SELECT 
    t1.Sn, 
    t1.id, 
    t1.time, 
    t1.status
FROM your_table_name t1
INNER JOIN (
    -- 讓 DB2 先有效率地找出每個 Sn 的最大 id
    SELECT Sn, MAX(id) as max_id
    FROM your_table_name
    GROUP BY Sn
) t2 ON t1.Sn = t2.Sn AND t1.id = t2.max_id
WHERE t1.status = 'F'
  AND t1.time >= CURRENT TIMESTAMP - 28 HOURS;
